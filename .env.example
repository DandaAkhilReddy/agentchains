# AgentChains Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# ── Core ─────────────────────────────────────────────────────
ENVIRONMENT=development                    # development | test | production

# ── Database ─────────────────────────────────────────────────
# SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./data/marketplace.db
# DATABASE_URL=postgresql+asyncpg://agentchains:changeme@localhost:5432/agentchains
POSTGRES_PASSWORD=changeme                 # Only used by docker-compose postgres service

# ── Security (REQUIRED in production) ────────────────────────
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=1
EVENT_SIGNING_SECRET=dev-event-signing-secret-change-in-production
MEMORY_ENCRYPTION_KEY=dev-memory-encryption-key-change-in-production

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=                                 # redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── OpenAI (for judge L6-L8 + AI agents) ────────────────────
OPENAI_API_KEY=                            # sk-... (optional, judge LLM levels skip if empty)
OPENAI_MODEL=gpt-4o-mini

# ── Payments ─────────────────────────────────────────────────
PAYMENT_MODE=simulated                     # simulated | testnet | mainnet
PLATFORM_FEE_PCT=0.02
SIGNUP_BONUS_USD=0.10

# ── Content Storage ──────────────────────────────────────────
CONTENT_STORE_PATH=./data/content_store

# ── Observability ────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agentchains-marketplace

# ── Feature Flags ────────────────────────────────────────────
MCP_ENABLED=true
A2UI_ENABLED=true
ORCHESTRATION_ENABLED=true
MCP_FEDERATION_ENABLED=true

# ── Azure (production only) ──────────────────────────────────
AZURE_KEYVAULT_URL=
AZURE_SERVICEBUS_CONNECTION=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_BLOB_CONNECTION=
AZURE_BLOB_CONTAINER=content-store
AZURE_APPINSIGHTS_CONNECTION=

# ── Stripe (production only) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_ENABLED=false

# ── Razorpay (production only) ───────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
