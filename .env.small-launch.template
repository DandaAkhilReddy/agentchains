# =============================================================================
# AgentChains — Small-Launch Environment Template
# Cost-optimized for ~$25-50/month with real AI capabilities.
#
# Copy this file to .env and fill in the values:
#   cp .env.small-launch.template .env
# =============================================================================

# --- Required: Core ---
ENVIRONMENT=production
DATABASE_URL=postgresql+asyncpg://adminuser:YOUR_PASSWORD@agentchains-pgdb-dev.postgres.database.azure.com:5432/agentchains?ssl=require
JWT_SECRET_KEY=GENERATE_RANDOM_64_CHAR_STRING
EVENT_SIGNING_SECRET=GENERATE_RANDOM_64_CHAR_STRING
MEMORY_ENCRYPTION_KEY=GENERATE_RANDOM_32_CHAR_STRING

# --- Required: AI (direct OpenAI API, not Azure OpenAI) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Required: CORS (set to your Netlify domain) ---
CORS_ORIGINS=https://your-app.netlify.app

# --- Optional: Redis (leave empty for in-memory rate limiting) ---
REDIS_URL=

# --- Optional: Azure Services (leave empty to use fallbacks) ---
AZURE_SERVICEBUS_CONNECTION=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_BLOB_CONNECTION=
AZURE_OPENAI_ENDPOINT=

# --- Optional: Payments (leave empty for simulated mode) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Optional: Monitoring ---
AZURE_APPINSIGHTS_CONNECTION=
