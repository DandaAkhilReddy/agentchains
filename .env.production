# ===========================================================================
# AgentChains — Production Environment Configuration
# ===========================================================================
# Copy to .env and fill in all <PLACEHOLDER> values before deploying.
# Lines marked REQUIRED will cause startup validation to fail if missing.
# ===========================================================================

# ---- Core ----
ENVIRONMENT=production
DEBUG=false

# ---- Database (REQUIRED) ----
# Use PostgreSQL in production. Never use SQLite.
DATABASE_URL=postgresql+asyncpg://<USER>:<PASSWORD>@<HOST>:5432/agentchains

# ---- Secrets (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))") ----
JWT_SECRET_KEY=<GENERATE-64-CHAR-RANDOM-STRING>
JWT_ALGORITHM=HS256
EVENT_SIGNING_SECRET=<GENERATE-64-CHAR-RANDOM-STRING>
MEMORY_ENCRYPTION_KEY=<GENERATE-64-CHAR-RANDOM-STRING>

# ---- Payment ----
PAYMENT_MODE=mainnet
STRIPE_SECRET_KEY=<STRIPE-SK-LIVE-KEY>
STRIPE_WEBHOOK_SECRET=<STRIPE-WHK-KEY>
RAZORPAY_KEY_ID=<RAZORPAY-KEY>
RAZORPAY_SECRET=<RAZORPAY-SECRET>

# ---- CORS (no localhost, no wildcard) ----
CORS_ORIGINS=https://agentchains.com,https://app.agentchains.com

# ---- Content Storage ----
CONTENT_STORE_PATH=/var/data/agentchains/content_store

# ---- MCP ----
MCP_ENABLED=true

# ---- Redis (session cache, rate limiting) ----
REDIS_URL=redis://<HOST>:6379/0

# ---- Azure Services ----
AZURE_KEY_VAULT_URL=https://<VAULT-NAME>.vault.azure.net/
AZURE_SERVICE_BUS_CONNECTION=<SERVICE-BUS-CONNECTION-STRING>
AZURE_AI_SEARCH_ENDPOINT=https://<SEARCH-NAME>.search.windows.net
AZURE_AI_SEARCH_KEY=<SEARCH-ADMIN-KEY>
AZURE_BLOB_CONNECTION=<BLOB-STORAGE-CONNECTION-STRING>
AZURE_BLOB_CONTAINER=agentchains-content
APPINSIGHTS_CONNECTION_STRING=<APP-INSIGHTS-CONNECTION-STRING>

# ---- OpenTelemetry ----
OTEL_EXPORTER_OTLP_ENDPOINT=https://<OTEL-COLLECTOR>:4318
OTEL_SERVICE_NAME=agentchains-api

# ---- Rate Limiting ----
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
